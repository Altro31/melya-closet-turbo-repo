{
  "name": "backend",
  "type": "module",
  "sideEffects": false,
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/export/index.js"
  },
  "scripts": {
    "dev": "turbo watch dev:turbo",
    "dev:turbo": "turbo build && pnpm start:dev",
    "start": "node dist/main.js",
    "start:dev": "node --env-file=.env dist/main.js",
    "build": "tsup",
    "base": "pnpm --dir ../.."
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.65",
    "@repo/db": "workspace:*",
    "@zenstackhq/orm": "^3.6.4",
    "@zenstackhq/zod": "^3.6.4",
    "effect": "4.0.0-beta.65",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/pg": "^8.15.6",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
