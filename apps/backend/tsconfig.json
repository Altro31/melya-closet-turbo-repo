{
  "compilerOptions": {
    "target": "es2020",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
    },
  },
}
