import "common"
import "user"
import "client"


model UserLog with IdMixin, TimestampMixin {
    action  String
    details String

    userId  String
    User    User   @relation(fields: [userId], references: [id])

    @@map('user_log')
}

model ClientLog with IdMixin, TimestampMixin {
    action   String
    details  String

    clientId String
    Client   Client @relation(fields: [clientId], references: [id])

    @@map('client_log')
}