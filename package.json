{
  "name": "melya-closet",
  "private": true,
  "scripts": {
    "apk": "pnpm --dir apps/apk",
    "db": "pnpm --dir packages/db",
    "back": "pnpm --dir=apps/backend",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:desktop": "pnpm --dir apps/apk run build:desktop",
    "build:android": "pnpm --dir apps/apk run build:android"
  },
  "devDependencies": {
    "turbo": "^2.9.10"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.0.9"
}
